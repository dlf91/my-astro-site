---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
const baseUrl = import.meta.env.BASE_URL;
---

<MainLayout title="Services">
  <Breadcrumb title="Services" />
  <section id="main-container" class="main-container">
    <div class="container">
      <div class="row">
        <div class="col-xl-3 col-lg-4">
          <div class="sidebar sidebar-left">
            <div class="widget">
              <h3 class="widget-title">Services</h3>
              <ul class="nav service-menu">
                <li>
                  <a href={ baseUrl + "services_mobile"}
                    >Mobile Vehicle Service & Maintenance</a
                  >
                </li>
                <li class="active">
                  <a href={ baseUrl + "services_auto"}>Auto Electrician Services</a>
                </li>
                <li>
                  <a href={ baseUrl + "services_air"}
                    >Automotive Air Conditioning Regas & Maintenance</a
                  >
                </li>
              </ul>
            </div>
            <!-- Widget end -->
          </div>
          <!-- Sidebar end -->
        </div>
        <!-- Sidebar Col end -->

        <div class="col-xl-8 col-lg-8">
          <div class="content-inner-page">
            <h2 class="column-title mrt-0">Auto Electrician Services</h2>

            <div class="row">
              <div class="col-md-12 text-justify">
                <p>
                  Our <b>mobile auto electrician service</b> provides reliable
                  automotive electrical diagnostics, repairs, and installations
                  throughout the Mackay region. Modern vehicles depend heavily
                  on electrical systems that control starting, charging,
                  lighting, safety systems, and electronic accessories.
                </p>
                <p>
                  Electrical faults can often be difficult to diagnose without
                  specialised tools and experience. Our mobile service brings
                  <b
                    >professional diagnostic equipment and expert knowledge
                    directly to your location</b
                  >, allowing us to efficiently identify and repair electrical
                  issues without the need for a workshop visit.
                </p>
                <p>
                  Whether your vehicle has
                  <b
                    >starting problems, battery issues, wiring faults, or
                    requires accessory installations</b
                  >, we provide professional solutions to keep your vehicle
                  running safely and reliably.
                </p>
              </div>
              <!-- col end -->
            </div>
            <!-- 1st row end-->

            <div class="gap-40"></div>
            <div id="page-slider" class="page-slider">
              <div class="item">
                <img
                  loading="lazy"
                  class="img-fluid"
                  src={ baseUrl + "assets/images/projects/project3.jpg"}
                  alt="project-slider-image"
                />
              </div>

              <div class="item">
                <img
                  loading="lazy"
                  class="img-fluid"
                  src={ baseUrl + "assets/images/projects/project4.jpg"}
                  alt="project-slider-image"
                />
              </div>
            </div>
            <!-- Page slider end -->

            <div class="gap-40"></div>

            <div class="row">
              <div class="col-md-12">
                <h5 class="text-primary">
                  Auto Electrical Services We Provide
                </h5>
                <p class="text-justify">
                  <b>Electrical Diagnostics & Fault Finding</b><br />
                  We use modern diagnostic equipment to locate electrical faults
                  quickly and accurately, saving time and unnecessary repairs.
                </p>
                <p class="text-justify">
                  <b>Battery Testing & Replacement</b><br />
                  On-site battery testing and replacement services to ensure
                  reliable vehicle starting and electrical system performance.
                </p>
                 <p class="text-justify">
                  <b>Starter Motor & Alternator Repairs</b><br />
                  Diagnosis and repair of starter motors, alternators, and
                  charging systems to keep your vehicle operating properly.
                </p>
                 <p class="text-justify">
                  <b>Wiring Repairs & Electrical Troubleshooting</b><br />
                  Professional wiring repairs for damaged, faulty, or poorly
                  installed electrical systems.
                </p>
                <hr />
                <p class="text-justify">
                  <b>4×4 & Off-Road Electrical Installations</b><br />
                  We also specialise in 4WD and off-road accessory
                  installations, ensuring your vehicle is equipped with reliable
                  electrical systems for touring, work, or off-road adventures.
                </p>

                <b>Our 4×4 installations include:</b><br />
                <ul class="list-arrow">
                  <li>Spotlights and LED driving lights</li>
                  <li>Light bars and work lights</li>
                  <li>UHF radio installation</li>
                  <li>Dual battery systems</li>
                  <li>Anderson plugs and power outlets</li>
                  <li>Electric brake controllers</li>
                  <li>Rear work lights and canopy wiring</li>
                  <li>Additional power systems for camping and touring</li>
                </ul>

                <br />
                <p class="text-justify">
                  All installations are completed
                  <b
                    >professionally with safe wiring practices and quality
                    components</b
                  >, ensuring reliability in harsh off-road conditions.
                </p>
                <hr />
                <h5 class="text-primary">
                  Why Choose Our Mobile Auto Electrician
                </h5>
                <ul class="list-arrow">
                  <li>Mobile service anywhere in the Mackay region</li>
                  <li>Professional electrical diagnostics and repairs</li>
                  <li>Expert 4WD accessory installations</li>
                  <li>Convenient service at your home or workplace</li>
                  <li>Reliable and trusted workmanship</li>
                </ul>
                <hr />
                <h5 class="text-primary">Reliable Auto Electrical Solutions</h5>
                <p class="text-justify">
                  Our goal is to provide
                  <b>high-quality mobile auto electrical services</b> that keep
                  your vehicle’s electrical systems operating safely and
                  efficiently. With the convenience of on-site service and
                  professional expertise, we ensure your vehicle remains
                  <b>reliable, capable, and ready for any journey</b>.
                </p>
              </div>
            </div>
          </div>
          <!-- Content inner end -->
        </div>
        <!-- Content Col end -->
      </div>
      <!-- Main row end -->
    </div>
  </section>
</MainLayout>
