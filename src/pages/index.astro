---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
const baseUrl = import.meta.env.BASE_URL;

import mobileServiceImage from '../assets/images/services/service3.jpg';
import autoServiceImage from '../assets/images/services/service1.jpg';
import airServiceImage from '../assets/images/services/service2.jpg';



---
<MainLayout title="Home">
<div class="banner-carousel banner-carousel-1 mb-0">
  <div class="banner-carousel-item" style={`background-image:url(${baseUrl}assets/images/slider-main/bg1.jpg)`}>
    <div class="slider-content">
        <div class="container h-100">
          <div class="row align-items-center h-100">
              <div class="col-md-12 text-center">
                <h2 class="slide-title" data-animation-in="slideInLeft">We specialise in</h2>
                <h3 class="slide-sub-title" data-animation-in="slideInRight">Professional diagnostics and expert vehicle care</h3>
                <p data-animation-in="slideInLeft" data-duration-in="1.2">
                    <!-- <a href="/services" class="slider btn btn-primary">Our Services</a> -->
                    <a href={ baseUrl + "contact"} class="slider btn btn-primary border">Contact Now</a>
                </p>
              </div>
          </div>
        </div>
    </div>
  </div>

  <div class="banner-carousel-item" style={`background-image:url(${baseUrl}assets/images/slider-main/bg2.jpg)`}>
    <div class="slider-content text-left">
        <div class="container h-100">
          <div class="row align-items-center h-100">
              <div class="col-md-12">
                <h2 class="slide-title-box" data-animation-in="slideInDown">World Class Service</h2>
                <h3 class="slide-title" data-animation-in="fadeIn">Looking for a reliable mobile mechanic in Mackay?</h3>
                <h3 class="slide-sub-title" data-animation-in="slideInLeft">Your Choice is Simple</h3>
                <p data-animation-in="slideInRight">
                    <!-- <a href="services.html" class="slider btn btn-primary border">Our Services</a> -->
                </p>
              </div>
          </div>
        </div>
    </div>
  </div>

  <div class="banner-carousel-item" style={`background-image:url(${baseUrl}assets/images/slider-main/bg3.jpg)`}>
    <div class="slider-content text-right">
        <div class="container h-100">
          <div class="row align-items-center h-100">
              <div class="col-md-12">
                <h2 class="slide-title" data-animation-in="slideInDown">No waiting rooms. No towing. No wasted time</h2>
                <h3 class="slide-sub-title" data-animation-in="fadeIn">We come to you</h3>
                <!-- <p class="slider-description lead" data-animation-in="slideInRight">We will deal with your failure that determines how you achieve success.</p> -->
                <!-- <div data-animation-in="slideInLeft">
                    <a href="contact.html" class="slider btn btn-primary" aria-label="contact-with-us">Get Free Quote</a>
                    <a href="about.html" class="slider btn btn-primary border" aria-label="learn-more-about-us">Learn more</a>
                </div> -->
              </div>
          </div>
        </div>
    </div>
  </div>
</div>

<section class="call-to-action no-padding">
  <div class="container">
    <div class="action-style-box">
        <div class="row">
          <div class="col-md-8 text-center text-md-left">
              <div class="call-to-action-text">
                <h3 class="action-title">We understand what your vehicle needs</h3>
              </div>
          </div><!-- Col end -->
          <div class="col-md-4 text-center text-md-right mt-3 mt-md-0">
              <div class="call-to-action-btn">
                <a class="btn btn-primary" href={ baseUrl + "contact"}>Request Quote</a>
              </div>
          </div><!-- col end -->
        </div><!-- row end -->
    </div><!-- Action style box -->
  </div><!-- Container end -->
</section><!-- Action end -->

<section id="ts-features" class="ts-features solid-bg">
  <div class="container">    
   <div class="row">
         <div class="col-lg-6">
          <div class="ts-intro"> 
              <h2 class="into-title">ABOUT US</h2>
              <h3 class="into-sub-title">PROFESSIONAL MOBILE MECHANIC SERVICES AT YOUR LOCATION</h3>
              <p>Vantage Mobile Mechanic provides reliable and convenient vehicle repairs and servicing directly at your home, workplace, or roadside. We focus on honest advice, quality workmanship, and keeping you safely on the road.</p>
          </div><!-- Intro box end -->

          <div class="gap-20"></div>

          <div class="row">
              <div class="col-md-6">
                <div class="ts-service-box">
                    <span class="ts-service-icon">
                      <i class="fas fa-trophy"></i>
                    </span>
                    <div class="ts-service-box-content">
                      <h3 class="service-box-title">Reliable and Professional Service</h3>
                    </div>
                </div><!-- Service 1 end -->
              </div><!-- col end -->

              <div class="col-md-6">
                <div class="ts-service-box">
                    <span class="ts-service-icon">
                      <i class="fas fa-sliders-h"></i>
                    </span>
                    <div class="ts-service-box-content">
                      <h3 class="service-box-title">Quality Repairs and Maintenance</h3>
                    </div>
                </div><!-- Service 2 end -->
              </div><!-- col end -->
          </div><!-- Content row 1 end -->

          <div class="row">
              <div class="col-md-6">
                <div class="ts-service-box">
                    <span class="ts-service-icon">
                      <i class="fas fa-thumbs-up"></i>
                    </span>
                    <div class="ts-service-box-content">
                      <h3 class="service-box-title">Honest Advice and Fair Pricing</h3>
                    </div>
                </div><!-- Service 1 end -->
              </div><!-- col end -->

              <div class="col-md-6">
                <div class="ts-service-box">
                    <span class="ts-service-icon">
                      <i class="fas fa-users"></i>
                    </span>
                    <div class="ts-service-box-content">
                      <h3 class="service-box-title">Convenient Mobile Service at Your Location</h3>
                    </div>
                </div><!-- Service 2 end -->
              </div><!-- col end -->
          </div><!-- Content row 1 end -->
        </div><!-- Col end -->

        <div class="col-lg-6 mt-4 mt-lg-0">
          <h3 class="into-sub-title">Our Values</h3>
          <!--<p>Minim Austin 3 wolf moon scenester aesthetic, umami odio pariatur bitters. Pop-up occaecat taxidermy street art, tattooed beard literally.</p>-->

          <div class="accordion accordion-group" id="our-values-accordion">
              <div class="card">
                <div class="card-header p-0 bg-transparent" id="headingOne">
                    <h2 class="mb-0">
                      <button class="btn btn-block text-left" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                          Reliable Service
                      </button>
                    </h2>
                </div>
              
                <div id="collapseOne" class="collapse show" aria-labelledby="headingOne" data-parent="#our-values-accordion">
                    <div class="card-body">
                      We arrive on time and complete work professionally with attention to detail.
                    </div>
                </div>
              </div>
              <div class="card">
                <div class="card-header p-0 bg-transparent" id="headingTwo">
                    <h2 class="mb-0">
                      <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                          Customer Service
                      </button>
                    </h2>
                </div>
                <div id="collapseTwo" class="collapse" aria-labelledby="headingTwo" data-parent="#our-values-accordion">
                    <div class="card-body">
                      We put customers first and explain repairs clearly before carrying out any work.
                    </div>
                </div>
              </div>
              <div class="card">
                <div class="card-header p-0 bg-transparent" id="headingThree">
                    <h2 class="mb-0">
                      <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                          Honest Pricing
                      </button>
                    </h2>
                </div>
                <div id="collapseThree" class="collapse" aria-labelledby="headingThree" data-parent="#our-values-accordion">
                    <div class="card-body">
                      No hidden costs. Quotes are discussed before work begins.
                    </div>
                </div>
              </div>
              <div class="card">
                <div class="card-header p-0 bg-transparent" id="headingFour">
                    <h2 class="mb-0">
                      <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                          Quality Workmanship
                      </button>
                    </h2>
                </div>
                <div id="collapseFour" class="collapse" aria-labelledby="headingFour" data-parent="#our-values-accordion">
                    <div class="card-body">
                      We use quality parts and take pride in every job.
                    </div>
                </div>
              </div>
              <div class="card">
                <div class="card-header p-0 bg-transparent" id="headingFive">
                    <h2 class="mb-0">
                      <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseFive" aria-expanded="false" aria-controls="collapseFive">
                          Safety First
                      </button>
                    </h2>
                </div>
                <div id="collapseFive" class="collapse" aria-labelledby="headingFive" data-parent="#our-values-accordion">
                    <div class="card-body">
                      We inspect important vehicle components to help keep you and your family safe.
                    </div>
                </div>
              </div>
          </div>
          <!--/ Accordion end -->

        </div><!-- Col end -->             
         
    </div><!-- Content row end -->
   
  </div>
 
</section>

<section id="ts-features" class="ts-features pb-2">
  <div class="container">
    <div class="row text-center">
        <div class="col-12">
          <h2 class="section-title">We Are Specialists In</h2>
          <h3 class="section-sub-title text-primary">What We Do</h3>
        </div>
    </div>
    <div class="row">
         <div class="col-lg-4 col-md-6 mb-5">
          <div class="ts-service-box">
              <div class="ts-service-image-wrapper">
                <Image width="360" height="250" loading="lazy" class="w-100" src={ mobileServiceImage } alt="service-image">
              </div>
              <div class="d-flex"> 
                <div class="ts-service-info">
                    <h3 class="service-box-title"><a href={ baseUrl + "services_mobile"}>Mobile mechanic services</a></h3>
                    <div class="d-flex justify-content-center align-items-center  mb-2">
                    <i class="fa fa-solid fa-map-marker-alt text-danger fa-xs mr-1 "></i>  Mackay Region 
                    </div>
                    <p><b>Mobile services include:</b>
                      <ul class="list-arrow">
                        <li>Logbook servicing and routine maintenance</li>
                        <li>Electrical diagnostics and fault finding</li>
                        <li>Battery testing and replacement</li>
                        <li>Alternator and starter motor repairs</li>
                        <li>Wiring repairs and accessory installations</li>
                        <li>General vehicle inspections and maintenance</li>
                      </ul>
                      <hr>
                      <ul class="pl-0" style="list-style-type:none;"> 
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> We come to you anywhere in the Mackay region</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Convenient on-site servicing</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Professional diagnostics and repairs</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Reliable, high-quality workmanship</li>
                    </ul>
                    </p>
                    <a class="learn-more d-inline-block" href={ baseUrl + "services_mobile"} aria-label="Learn more about our mobile mechanic services"><i class="fa fa-caret-right"></i> Learn more</a>
                </div>
              </div>
          </div><!-- Service3 end -->
        </div><!-- Col 3 end -->

        <div class="col-lg-4 col-md-6 mb-5">
          <div class="ts-service-box">
              <div class="ts-service-image-wrapper">
                <Image width="360" height="250" loading="lazy" class="w-100" src={ autoServiceImage } alt="service-image">
              </div>
              <div class="d-flex"> 
                <div class="ts-service-info">
                    <h3 class="service-box-title"><a href={ baseUrl + "services_auto"}>Auto Electrician Services</a></h3>
                        <div class="d-flex justify-content-center align-items-center mb-2">
                    <i class="fa fa-solid fa-map-marker-alt text-danger fa-xs mr-1 "></i>  Mackay Region 
                    </div>
                    <p><b>Our Auto Electrical Services Include:</b>
                      <ul class="list-arrow">
                        <li>Electrical diagnostics and fault finding</li>
                        <li>Battery testing and replacement</li>
                        <li>Alternator and starter motor repairs</li>
                        <li>Wiring repairs and electrical troubleshooting</li>
                        <li>Vehicle accessory installations</li>                    
                        <li><b>4×4 and off-road electrical upgrades</b></li>
                      </ul>
                      <hr>
                      <ul class="pl-0" style="list-style-type:none;">
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Mobile service across the Mackay region</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Fast and accurate diagnostics</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Professional accessory installations</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Reliable workmanship you can trust</li> 
                      </ul>
                    </p>
                    <a class="learn-more d-inline-block" href={ baseUrl + "services_auto"} aria-label="Learn more about our auto electrical repair services"><i class="fa fa-caret-right"></i> Learn more</a>
                </div>
              </div>
          </div><!-- Service1 end -->
        </div><!-- Col 1 end -->

        <div class="col-lg-4 col-md-6 mb-5">
          <div class="ts-service-box">
              <div class="ts-service-image-wrapper">
                <Image width="360" height="250" loading="lazy" class="w-100" src={ airServiceImage } alt="service-image">
              </div>
              <div class="d-flex"> 
                <div class="ts-service-info">
                    <h3 class="service-box-title"><a href={ baseUrl + "services_air"}>Car Air Conditioning</a></h3>
                     <div class="d-flex justify-content-center align-items-center mb-2">
                    <i class="fa fa-solid fa-map-marker-alt text-danger fa-xs mr-1 "></i>  Mackay Region 
                    </div>
                    <p><b>Our Air Conditioning Services Include:</b>
                      <ul class="list-arrow">
                        <li>Air conditioning system regas</li>
                        <li>System performance testing and inspection</li>
                        <li>Leak detection and system diagnostics</li>
                        <li>Compressor and component checks</li>
                        <li>Cabin air filter inspection and replacement</li>
                        <li>General air conditioning maintenance</li>
                      </ul>
                      <hr>
                      <ul class="pl-0" style="list-style-type:none;"> 
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Professional automotive air conditioning servicing</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Quality equipment and approved refrigerants</li>
                        <li> <i class="fa fa-solid fa-check fa-xs"></i> Reliable cooling performance for your vehicle</li>
                    </ul>
                    </p>
                    <a class="learn-more d-inline-block" href={ baseUrl + "services_air"} aria-label="Learn more about our car air conditioning services"><i class="fa fa-caret-right"></i> Learn more</a>
                </div>
              </div>
          </div><!-- Service2 end -->
        </div><!-- Col 2 end -->

     
    </div><!-- Content row end -->
  </div><!-- Container end -->
</section><!-- Feature are end -->
 


</MainLayout>