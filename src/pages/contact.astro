  <!-- Google Map API Key-->
  <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyD3pS_KxDMA9ariSTAbqlxx7VtMaU3TIwU" defer></script>
  <!-- Google Map Plugin-->
  <script src={ baseUrl + "assets/plugins/google-map/map.js" } defer></script>

</MainLayout>