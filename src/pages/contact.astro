---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
const baseUrl = import.meta.env.BASE_URL;
---
<MainLayout title="Contact">
  <Breadcrumb title="Contact"/>
  <section id="main-container" class="main-container">
  <div class="container">

    <div class="row text-center">
      <div class="col-12">
        <h2 class="section-title">Reaching our Office</h2>
        <h3 class="section-sub-title">Find Our Location</h3>
      </div>
    </div>
    <!--/ Title row end -->

    <div class="row">
      <div class="col-md-4">
        <div class="ts-service-box-bg text-center h-100">
          <span class="ts-service-icon icon-round">
            <i class="fas fa-map-marker-alt mr-0"></i>
          </span>
          <div class="ts-service-box-content">
            <h4>Visit Our Office</h4>
            <p>4740 Mackay, Australia</p>
          </div>
        </div>
      </div><!-- Col 1 end -->

      <div class="col-md-4">
        <div class="ts-service-box-bg text-center h-100">
          <span class="ts-service-icon icon-round">
            <i class="fa fa-envelope mr-0"></i>
          </span>
          <div class="ts-service-box-content">
            <h4>Email Us</h4>
            <p>Info@vantagemobilemechanic.com.au</p>
          </div>
        </div>
      </div><!-- Col 2 end -->

      <div class="col-md-4">
        <div class="ts-service-box-bg text-center h-100">
          <span class="ts-service-icon icon-round">
            <i class="fa fa-phone-square mr-0"></i>
          </span>
          <div class="ts-service-box-content">
            <h4>Call Us</h4>
            <p>+61 431 979 123</p>
          </div>
        </div>
      </div><!-- Col 3 end -->

    </div><!-- 1st row end -->

    <div class="gap-60"></div>

    <div class="google-map">
      <div 
        id="map"
        class="map" 
        data-latitude="-21.1425" 
        data-longitude="149.1868" 
        data-marker={baseUrl + "assets/images/marker.png"} 
        data-marker-name="Vantage Mobile Mechanic">
      </div>
      <!-- <div id="map" class="map" data-latitude="40.712776" data-longitude="-74.005974" data-marker={baseUrl + "assets/images/marker.png"} data-marker-name="Constra"></div> -->
    </div>

    <div class="gap-40"></div>

    <div class="row">
      <div class="col-md-12">
        <h3 class="column-title">We love to hear</h3>
        <!-- contact form works with formspree.io  -->
        <!-- contact form activation doc: https://docs.themefisher.com/constra/contact-form/ -->
        <form action="/send-email.php" method="POST" id="contact-form" novalidate> 
 
          <div class="error-container"></div>
          <div class="honey-container" style="display: none !important;" aria-hidden="true">
            <label for="website_honey">Leave this field blank if you are human</label>
            <input type="text" name="website_honey" id="website_honey" autocomplete="off" tabindex="-1" />
          </div>
          <div class="row">
            <div class="col-md-4">
              <div class="form-group">
                <label>Name</label>
                <input 
                  type="text" 
                  name="name" 
                  id="name" 
                  required 
                  minlength="2"
                  class="form-control form-control-name"
                  placeholder="John Doe"
                /> 
              </div>
            </div>
            <div class="col-md-4">
              <div class="form-group">
                <label>Email</label>
                <input class="form-control form-control-email" name="email" id="email" placeholder="name@example.com" type="email"
                  required>
              </div>
            </div>
        
            <div class="col-md-4">
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input 
                  type="text" 
                  name="phone" 
                  id="phone" 
                  required
                  maxlength="10" 
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="form-control" 
                  placeholder="0412345678"
                />
                <small class="text-muted">Maximum 10 digits allowed (numbers only).</small>
                 
                <!-- <input class="form-control form-control-subject" name="subject" id="subject" placeholder="" required> -->
              </div>
            </div>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea class="form-control form-control-message" name="message" id="message" rows="5" 
                required 
                minlength="10"  
                placeholder="Please describe the vehicle issue or service required..."
              required></textarea>
          </div>
          <div class="text-right"><br> 
            <button class="btn btn-primary solid blank" type="submit">Send Message</button>
          </div>
        </form>
      </div>

    </div><!-- Content row -->
  </div><!-- Conatiner end -->
</section><!-- Main container end -->

<script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script is:inline>
  const form = document.getElementById('contact-form');

  if (form) {
    form.addEventListener('submit', async (e) => {
      // 1. STOP the form immediately so we can inspect it
      e.preventDefault(); 

      // 2. CRITICAL: Ask the browser if the HTML5 constraints are satisfied
      if (!form.checkValidity()) {
        // If it's invalid, force the browser to display its built-in error bubbles
        form.reportValidity(); 
        return; // Halt execution here! Do not run the SweetAlert code below.
      }

      // 3. Only if valid, trigger the SweetAlert loading display
      Swal.fire({
        title: 'Sending Request...',
        text: 'Please wait while we transmit your details.',
        allowOutsideClick: false,
        didOpen: () => {
          Swal.showLoading();
        }
      });

      const formData = new FormData(form);

      try {
        const response = await fetch('/send-email.php', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();

        if (response.ok && result.status === 'success') {
          Swal.fire({
            icon: 'success',
            title: 'Message Sent!',
            text: 'Thank you! Your message has been sent successfully.',
            confirmButtonColor: '#28a745'
          });
          form.reset(); 
        } else {
          throw new Error(result.message || 'Submission failed');
        }
      } catch (error) {
        Swal.fire({
          icon: 'error',
          title: 'Submission Failed',
          text: error.message || 'An error occurred. Please try again.',
          confirmButtonColor: '#dc3545'
        });
      }
    });
  }
</script>

