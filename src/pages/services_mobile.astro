---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---
<MainLayout title="Services"> 
<Breadcrumb title="Services" />
 <section id="main-container" class="main-container">
  <div class="container">
    <div class="row">
      <div class="col-xl-3 col-lg-4">
        <div class="sidebar sidebar-left">
          <div class="widget">
            <h3 class="widget-title">Services</h3>
            <ul class="nav service-menu">
              <li class="active"><a href={ baseUrl + "services_mobile"}>Mobile Vehicle Service & Maintenance</a></li>
              <li><a href={ baseUrl + "services_auto"}>Auto Electrician Services</a></li>
              <li><a href={ baseUrl + "services_air"}>Automotive Air Conditioning Regas & Maintenance</a></li> 
            </ul>
          </div>           
        </div><!-- Sidebar end -->
      </div><!-- Sidebar Col end -->

      <div class="col-xl-8 col-lg-8">
        <div class="content-inner-page">

          <h2 class="column-title mrt-0">Mobile Vehicle Service & Maintenance</h2>

          <div class="row">
            <div class="col-md-12 text-justify">
              <p>Our <b>mobile vehicle service and maintenance in the Mackay region</b> delivers professional automotive care directly to your location. Whether you are at <b>home, work, or stuck on the roadside</b>, our fully equipped mobile service vehicle allows us to diagnose, service, and repair your vehicle without the inconvenience of visiting a workshop.</p>
              
              <p>We use modern diagnostic equipment and quality parts to ensure every service is completed to a high professional standard. All work is carried out <b>according to manufacturer specifications</b>, helping maintain your vehicle’s reliability, safety, and warranty requirements.</p>
              
              <p>Our mobile service is designed to <b>save you time while keeping your vehicle running at its best</b>.
             
            </div><!-- col end -->
          </div><!-- 1st row end-->

          <div class="gap-40"></div>

          <div id="page-slider" class="page-slider">
            <div class="item">
              <img loading="lazy" class="img-fluid" src={ baseUrl + "assets/images/projects/project1.jpg"} alt="project-slider-image" />
            </div>

            <div class="item">
              <img loading="lazy" class="img-fluid" src={ baseUrl + "/assets/images/projects/project2.jpg"} alt="project-slider-image" />
            </div>
          </div><!-- Page slider end -->

          <div class="gap-40"></div>

          <div class="row">
            <div class="col-md-12 text-justify">
              <h5 class="text-primary">Our Mobile Vehicle Services</h5>

              <p>We provide a wide range of mobile automotive services, including:</p>

              <p><b>Logbook Servicing</b>Routine servicing carried out according to manufacturer specifications to maintain performance, reliability, and warranty protection.</p>
              <p><b>Electrical Diagnostics & Fault Finding</b><br>Advanced diagnostic tools allow us to quickly identify and repair electrical issues affecting your vehicle.</p>
              <p><b>Battery Services</b><br>Battery testing, replacement, and charging system checks to ensure reliable starting and electrical performance.</p>
              <p><b>Starter Motor & Alternator Repairs</b><br>Diagnosis and repair of starting and charging system components to keep your vehicle operating correctly.</p>
              <p><b>Wiring Repairs & Accessory Installations</b><br>Professional wiring repairs and installation of vehicle accessories such as lighting, power outlets, and other electrical components.</p>
              <p><b>General Vehicle Maintenance & Inspections</b><br>Comprehensive inspections and maintenance to identify potential issues early and keep your vehicle in excellent condition.</p>
          
              <h5 class="text-primary">Why Choose Our Mobile Vehicle Service</h5>
              <p>Our mobile service is designed to provide maximum convenience without compromising on quality.</p>
              <ul class="list-arrow">
                <li>Servicing at your location anywhere in the Mackay region</li>
                <li>Save time by avoiding workshop visits</li>
                <li>Professional automotive diagnostics and repairs</li>
                <li>Quality parts and reliable workmanship</li>
                <li>Honest, dependable service you can trust</li> 
              </ul>
            </div>

          
          </div> 

        </div><!-- Content inner end -->
      </div><!-- Content Col end -->
    </div><!-- Main row end -->
  </div>
  </div>
</MainLayout>